    "language": "html",
    "content": "<!DOCTYPE html>\n<html lang=\"en\" class=\"\"><head><script>window.livecodes = window.livecodes || {};</script><title>Untitled Project</title><meta name=\"title\" content=\"Untitled Project\"><meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link rel=\"stylesheet\" href=\"./style.css\"><script src=\"https://cdn.jsdelivr.net/npm/es-module-shims@1.10.0/dist/es-module-shims.js\" async=\"\"></script><script type=\"importmap\">{\n  \"imports\": {}\n}</script></head><body>\n\n\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Aputuogya D/A JHS</title>\n\n<!-- GEN Z MODERN FONTS -->\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&amp;family=Space+Grotesk:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\">\n\n<style>\n*{\n  margin:0;\n  padding:0;\n  box-sizing:border-box;\n  font-family:\"Space Grotesk\",\"Poppins\",sans-serif;\n}\n\nhtml{scroll-behavior:smooth;}\n\nbody{\n  color:#f1f5f9;\n}\n\n/* 🌫️ BLURRED BACKGROUND */\nbody::before{\n  content:\"\";\n  position:fixed;\n  top:0;\n  left:0;\n  width:100%;\n  height:100%;\n  background:url(\"https://pcfgbsoetouzasxpovqo.supabase.co/storage/v1/object/public/uploads/Screenshot_20260417_225146_Google.jpg\") no-repeat center center / cover;\n  filter:blur(12px);\n  transform:scale(1.1);\n  z-index:-2;\n}\n\nbody::after{\n  content:\"\";\n  position:fixed;\n  top:0;\n  left:0;\n  width:100%;\n  height:100%;\n  background:rgba(10,15,30,0.75);\n  z-index:-1;\n}\n\n/* NAV */\nnav{\n  display:flex;\n  justify-content:space-between;\n  align-items:center;\n  padding:15px 40px;\n  background:rgba(0,0,0,0.5);\n  backdrop-filter:blur(10px);\n  position:sticky;\n  top:0;\n  z-index:1000;\n}\n\nnav h2{color:#38bdf8;}\n\nnav a{\n  color:white;\n  margin-left:20px;\n  text-decoration:none;\n}\n\nnav a:hover{color:#38bdf8;}\n\n/* HERO */\n.hero{\n  height:90vh;\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  text-align:center;\n}\n\n.hero-box{\n  background:rgba(0,0,0,0.45);\n  padding:40px;\n  border-radius:18px;\n  backdrop-filter:blur(10px);\n}\n\n.hero h1{font-size:3rem;}\n.hero p{color:#cbd5f5;}\n.badge{color:#38bdf8;margin-top:10px;font-weight:600;}\n\n/* SECTIONS */\nsection{\n  padding:60px 20px;\n  max-width:1100px;\n  margin:auto;\n}\n\nh2{\n  text-align:center;\n  margin-bottom:30px;\n}\n\n/* GRID */\n.grid{\n  display:grid;\n  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));\n  gap:20px;\n}\n\n/* CARD */\n.card{\n  background:rgba(30,41,59,0.85);\n  padding:20px;\n  border-radius:14px;\n  backdrop-filter:blur(8px);\n}\n\n/* STATS */\n.stat{text-align:center;}\n.stat h1{color:#38bdf8;font-size:2.5rem;}\n\n/* GALLERY */\n.gallery{\n  display:grid;\n  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));\n  gap:15px;\n}\n\n.gallery img,\n.gallery video{\n  width:100%;\n  border-radius:12px;\n  aspect-ratio:16/9;\n  object-fit:cover;\n}\n\n/* CONTACT */\n.contact-box{\n  max-width:700px;\n  margin:auto;\n  background:rgba(30,41,59,0.9);\n  padding:30px;\n  border-radius:16px;\n  backdrop-filter:blur(10px);\n}\n\ninput,textarea{\n  width:100%;\n  padding:14px;\n  margin-top:10px;\n  border:none;\n  border-radius:10px;\n  background:rgba(15,23,42,0.6);\n  color:white;\n  outline:none;\n}\n\nbutton{\n  width:100%;\n  margin-top:15px;\n  padding:14px;\n  border:none;\n  border-radius:10px;\n  background:linear-gradient(135deg,#38bdf8,#0ea5e9);\n  font-weight:700;\n  cursor:pointer;\n}\n\nbutton:hover{transform:scale(1.03);}\n\n#status{margin-top:10px;color:#38bdf8;text-align:center;}\n\n/* FOOTER */\nfooter{\n  text-align:center;\n  padding:20px;\n  background:rgba(0,0,0,0.6);\n}\n</style>\n\n\n\n\n<!-- NAV -->\n<nav>\n  <h2>Aputuogya JHS</h2>\n  <div>\n    <a href=\"#home\">Home</a>\n    <a href=\"#about\">About</a>\n    <a href=\"#gallery\">Gallery</a>\n    <a href=\"#contact\">Contact</a>\n  </div>\n</nav>\n\n<!-- HERO -->\n<section class=\"hero\" id=\"home\">\n  <div class=\"hero-box\">\n    <h1>Aputuogya D/A JHS</h1>\n    <p>Excellence • Discipline • Knowledge</p>\n    <p class=\"badge\">10+ Years of Academic Excellence</p>\n  </div>\n</section>\n\n<!-- ABOUT (COMPLETE SCHOOL PROFILE) -->\n<section id=\"about\">\n  <h2>About Our School</h2>\n\n  <div class=\"grid\">\n\n    <div class=\"card\">\n      <h3> Overview</h3>\n      <p>\n        Aputuogya D/A Junior High School is a respected basic education institution\n        dedicated to shaping young minds through quality education, discipline, and\n        moral upbringing. The school has served the community for over 10+ years.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3> History</h3>\n      <p>\n        Established to improve access to education in the community, the school has\n        grown steadily and produced many successful students who continue their\n        education in senior high schools across Ghana.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3> Mission</h3>\n      <p>\n        To provide a safe and supportive learning environment that builds knowledge,\n        discipline, creativity, and responsibility in students.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3> Vision</h3>\n      <p>\n        To become a leading junior high school known for academic excellence,\n        innovation, and producing future leaders.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3> Core Values</h3>\n      <ul>\n        <li>Discipline</li>\n        <li>Respect</li>\n        <li>Integrity</li>\n        <li>Hard Work</li>\n        <li>Excellence</li>\n        <li>Leadership</li>\n      </ul>\n    </div>\n\n    <div class=\"card\">\n      <h3> Academics</h3>\n      <p>\n        Subjects include Mathematics, English, Science, ICT, Social Studies,\n        RME, and Creative Arts, following the Ghana Education Service curriculum.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3>Teaching</h3>\n      <p>\n        We use student-centered learning, combining modern ICT tools and traditional\n        methods to improve understanding and engagement.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3> Facilities</h3>\n      <p>\n        The school provides classrooms, learning resources, ICT access, and space\n        for sports and extracurricular activities.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3>Student Life</h3>\n      <p>\n        Students participate in sports, cultural events, clubs, and leadership\n        activities that build confidence and teamwork.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3>Staff</h3>\n      <p>\n        Dedicated teachers and leadership staff ensure discipline, academic excellence,\n        and student success.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3> Community</h3>\n      <p>\n        The school plays a major role in community development by educating future\n        leaders and responsible citizens.\n      </p>\n    </div>\n\n    <div class=\"card\">\n      <h3> Achievement</h3>\n      <p>\n        Strong BECE performance with many students gaining admission into top senior\n        high schools.\n      </p>\n    </div>\n\n  </div>\n</section>\n\n<!-- STATS -->\n<section>\n  <h2>Our Impact</h2>\n  <div class=\"grid\">\n    <div class=\"card stat\"><h1>10+</h1><p>Years</p></div>\n    <div class=\"card stat\"><h1>1000+</h1><p>Students</p></div>\n    <div class=\"card stat\"><h1>95%</h1><p>Success</p></div>\n  </div>\n</section>\n\n<!-- GALLERY -->\n<section id=\"gallery\">\n  <h2>Gallery</h2>\n  <div class=\"gallery\">\n\n    <video controls=\"\">\n      <source src=\"https://pcfgbsoetouzasxpovqo.supabase.co/storage/v1/object/public/uploads/f862df780bbaab2a24ade84a1608b762.mp4\">\n    </video>\n\n    <video controls=\"\">\n      <source src=\"https://pcfgbsoetouzasxpovqo.supabase.co/storage/v1/object/public/uploads/ebb5621f1647dfd4efac7324cd6a0dca.mp4\">\n    </video>\n\n    <video controls=\"\">\n      <source src=\"https://pcfgbsoetouzasxpovqo.supabase.co/storage/v1/object/public/uploads/c16b08750572cac1ccda15fe222ea333.mp4\">\n    </video>\n\n    <video controls=\"\">\n      <source src=\"https://pcfgbsoetouzasxpovqo.supabase.co/storage/v1/object/public/uploads/60cd3e8c7cef43de91e819c3508b87e7.mp4\">\n    </video>\n\n  </div>\n</section>\n\n<!-- CONTACT -->\n<section id=\"contact\">\n  <h2>Contact Us</h2>\n\n  <div class=\"contact-box\">\n    <form onsubmit=\"sendMessage(event)\">\n      <input id=\"name\" placeholder=\"Your Name\" required=\"\">\n      <input id=\"email\" type=\"email\" placeholder=\"Your Email\" required=\"\">\n      <textarea id=\"message\" placeholder=\"Your Message\" required=\"\"></textarea>\n      <button>Send Message</button>\n      <p id=\"status\"></p>\n    </form>\n  </div>\n</section>\n\n<!-- FOOTER -->\n<footer>\n  <p>© 2026 Aputuogya D/A JHS</p>\n</footer>\n\n\n<script src=\"./script.js\"></script></body></html>"
